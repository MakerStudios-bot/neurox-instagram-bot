# Variables de entorno para el bot de Instagram

# Token para verificar el webhook con Meta
VERIFY_TOKEN=your_verify_token_here

# Token de acceso de Instagram (obtenido desde Meta for Developers)
ACCESS_TOKEN=your_instagram_access_token_here

# ID de tu cuenta de negocio de Instagram
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_account_id_here

# Secret de la app (para validación HMAC)
APP_SECRET=your_app_secret_here

# Clave de API de Anthropic para usar Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Puerto (Railway lo asigna automáticamente)
PORT=5000
