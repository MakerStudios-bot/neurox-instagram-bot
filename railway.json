{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "cd vendedor && gunicorn app:app --bind 0.0.0.0:$PORT --workers 1 --timeout 120",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 10
  },
  "envs": {
    "VERIFY_TOKEN": {
      "description": "Token para verificar webhook de Meta"
    },
    "APP_SECRET": {
      "description": "Secret de tu app Meta"
    },
    "ANTHROPIC_API_KEY": {
      "description": "API key de Anthropic (Claude)"
    },
    "ADMIN_USER": {
      "description": "Usuario para dashboard admin",
      "default": "admin"
    },
    "ADMIN_PASS": {
      "description": "Contraseña para dashboard admin"
    },
    "PORT": {
      "description": "Puerto",
      "default": "5000"
    }
  }
}
